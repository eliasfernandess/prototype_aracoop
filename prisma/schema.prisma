generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Link {
  id           Int      @id @default(autoincrement())
  titulo       String
  descricao    String?
  urlDestino   String
  categoria    String?
  icone        String?  @default("link")
  corIcone     String?  @default("#00B4A0")
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  ordem        Int      @default(0)
  ativo        Boolean  @default(true)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("links")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senhaHash String
  criadoEm DateTime @default(now())

  @@map("usuarios")
}

model Categoria {
  id   Int    @id @default(autoincrement())
  nome String
  slug String @unique

  @@map("categorias")
}

model Configuracao {
  id        Int      @id @default(autoincrement())
  chave     String   @unique
  valor     String   @default("")
  criadoEm DateTime @default(now())

  @@map("configuracoes_app")
}
